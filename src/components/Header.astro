---
---

<header class="site-header">
  <nav class="nav-inner">
    <a href="/" class="nav-logo">MQ_</a>
    <button class="hamburger" aria-label="Toggle menu">
      <span class="line"></span>
      <span class="line"></span>
      <span class="line"></span>
    </button>
    <ul class="nav-links">
      <li><a href="/#about">About</a></li>
      <li><a href="/#skills">Skills</a></li>
      <li><a href="/#projects">Projects</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="/blog" class="nav-blog">Blog</a></li>
    </ul>
    <button id="theme-toggle" class="theme-switch" aria-label="Toggle dark mode">
      <!-- Sun -->
      <svg class="switch-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="butt">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="4"/>
        <line x1="12" y1="20" x2="12" y2="23"/>
        <line x1="1" y1="12" x2="4" y2="12"/>
        <line x1="20" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/>
        <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/>
        <line x1="19.78" y1="4.22" x2="17.66" y2="6.34"/>
        <line x1="6.34" y1="17.66" x2="4.22" y2="19.78"/>
      </svg>
      <div class="switch-track">
        <div class="switch-knob"></div>
      </div>
      <!-- Moon -->
      <svg class="switch-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle') as HTMLButtonElement;
  const root = document.documentElement;

  toggle.addEventListener('click', () => {
    root.classList.toggle('dark');
    localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 2px solid var(--color-border);
    transition: background 0.2s, border-color 0.2s;
  }

  :global(html.dark) .site-header {
    background: rgba(10, 10, 10, 0.92);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .nav-logo:hover {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    gap: 0;
    align-items: center;
  }

  .nav-links a {
    display: block;
    padding: 0 1.25rem;
    height: 56px;
    line-height: 56px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    border-bottom: 2px solid transparent;
    transition: color 0.1s, border-color 0.1s;
  }

  .nav-links a:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  .nav-blog {
    background: var(--color-accent);
    color: #0a0a0a !important;
    border: 2px solid var(--color-border);
    margin-left: 0.75rem;
    height: auto !important;
    line-height: normal !important;
    padding: 0.4rem 1rem !important;
    border-bottom: 2px solid var(--color-border) !important;
    box-shadow: 3px 3px 0 var(--color-border);
    transition: box-shadow 0.1s, transform 0.1s !important;
  }

  .nav-blog:hover {
    box-shadow: 1px 1px 0 var(--color-border) !important;
    transform: translate(2px, 2px);
    border-bottom-color: var(--color-border) !important;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
  }

  /* ── Theme switch ── */

  .theme-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }

  .switch-icon {
    display: block;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .switch-track {
    position: relative;
    width: 40px;
    height: 20px;
    background: var(--color-border-subtle);
    border: 2px solid var(--color-border);
    transition: background 0.2s;
    flex-shrink: 0;
  }

  :global(html.dark) .switch-track {
    background: var(--color-accent);
  }

  .switch-knob {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 12px;
    height: 12px;
    background: var(--color-text);
    transition: transform 0.2s;
  }

  :global(html.dark) .switch-knob {
    transform: translateX(20px);
    background: var(--color-invert-bg);
  }

  @media (max-width: 640px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      position: fixed;
      top: 58px;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 2px solid var(--color-border);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav-links.expanded {
      display: flex;
    }

    .nav-links a {
      height: auto;
      line-height: normal;
      padding: 1rem 2rem;
      border-bottom: 1px solid var(--color-border-subtle);
    }

    .nav-blog {
      margin-left: 0 !important;
      border: none !important;
      box-shadow: none !important;
      background: var(--color-accent) !important;
    }
  }
</style>
