---
---

<section id="hero" class="hero-section">
  <div class="hero-inner">
    <div class="hero-content-top">
      <span class="section-label">// founding engineer & builder</span>
      <h1 class="hero-name">Martin<br />Cordero</h1>
    </div>
    <div class="hero-portrait">
      <img
        src="https://avatars.githubusercontent.com/u/38227325?v=4"
        alt="Martin Cordero"
        class="hero-avatar"
      />
    </div>
    <div class="hero-content-bottom">
      <p class="hero-tagline">Full Stack SWE by day.</p>
      <p class="hero-tagline">White-hat hacker & builder by night.</p>
      <div class="hero-cta">
        <a href="#projects" class="btn">View Work</a>
        <a href="#contact" class="btn btn-ghost">Contact</a>
      </div>
      <div class="hero-social">
        <a href="https://github.com/magnusquest" target="_blank" rel="noopener">GitHub</a>
        <span class="sep">/</span>
        <a href="https://linkedin.com/in/martin-alejandro-cordero/" target="_blank" rel="noopener">LinkedIn</a>
        <span class="sep">/</span>
        <a href="https://x.com/matrix_quest" target="_blank" rel="noopener">X</a>
      </div>
    </div>
  </div>
  <a href="#about" class="scroll-arrow" aria-label="Scroll to next section">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>
</section>

<style>
  .hero-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    background: transparent;
    position: relative;
  }

  .scroll-arrow {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 2px solid var(--color-border-subtle);
    transition: color 0.15s, border-color 0.15s;
    animation: bounce 2s ease-in-out infinite;
  }

  .scroll-arrow:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 3rem;
    align-items: center;
  }

  .hero-content-top {
    grid-column: 1;
    grid-row: 1;
    align-self: end;
  }

  .hero-content-bottom {
    grid-column: 1;
    grid-row: 2;
    align-self: start;
  }

  .hero-portrait {
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 700;
    line-height: 0.95;
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
  }

  .hero-tagline {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 420px;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 3rem 0;
  }

  .hero-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-social a {
    color: var(--color-text-muted);
    border-bottom: 2px solid transparent;
    padding-bottom: 1px;
    transition: color 0.1s, border-color 0.1s;
  }

  .hero-social a:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  .sep {
    color: var(--color-border-subtle);
  }

  .hero-avatar {
    width: clamp(210px, 27vw, 330px);
    height: clamp(210px, 27vw, 330px);
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--color-border);
    box-shadow: var(--shadow-brutal-lg);
    display: block;
  }

  @media (max-width: 600px) {
    .hero-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 3rem 2rem 5rem;
    }

    .hero-content-top {
      order: 1;
      text-align: left;
      width: 100%;
    }

    .hero-portrait {
      order: 2;
      padding: 0;
      width: 100%;
      justify-content: center;
    }

    .hero-content-bottom {
      order: 3;
      width: 100%;
    }

    .hero-name {
      margin: 0 0 0.5rem;
    }

    .hero-tagline {
      margin: 0;
    }

    .hero-cta {
      margin: 1.25rem 0;
    }

    .hero-avatar {
      width: 200px;
      height: 200px;
    }
  }
</style>
