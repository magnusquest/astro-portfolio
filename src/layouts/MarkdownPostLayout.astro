---
const { frontmatter } = Astro.props;
import '../styles/global.css';
import BaseLayout from './BaseLayout.astro';
---

<BaseLayout
  title={`${frontmatter.title} — Martin Cordero`}
  description={frontmatter.description}
  image={frontmatter.image?.url}
>
  <article class="section-wrap prose">
    <a href="/blog" class="back-link">← Blog</a>
    <h1>{frontmatter.title}</h1>
    <div class="post-meta">
      <span>{frontmatter.pubDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      {frontmatter.author && <span>by {frontmatter.author}</span>}
    </div>
    {frontmatter.description && <p class="post-description">{frontmatter.description}</p>}
    {frontmatter.image?.url && (
      <div class="post-hero-img">
        <img src={frontmatter.image.url} alt={frontmatter.image.alt ?? frontmatter.title} />
      </div>
    )}
    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: color 0.1s, border-color 0.1s;
  }

  .back-link:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-border-subtle);
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 2rem;
  }

  .post-hero-img {
    border: 2px solid var(--color-border);
    box-shadow: var(--shadow-brutal);
    margin-bottom: 2.5rem;
    overflow: hidden;
  }

  .post-hero-img img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-body :global(h2),
  .post-body :global(h3) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-body :global(p) {
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .post-body :global(a) {
    border-bottom: 2px solid var(--color-accent);
  }

  .post-body :global(code) {
    font-family: var(--font-mono);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    padding: 0 4px;
    font-size: 0.875em;
  }

  .post-body :global(pre) {
    background: var(--color-text);
    color: var(--color-accent);
    padding: 1.5rem;
    border: 2px solid var(--color-border);
    box-shadow: var(--shadow-brutal);
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    border: none;
    color: inherit;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.5rem 1.5rem;
    background: var(--color-surface);
  }
</style>
